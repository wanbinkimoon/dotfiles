{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["oh-my-openagent@3.17.5", "@franlol/opencode-md-table-formatter@latest"],
  "small_model": "github-copilot/claude-haiku-4.5",
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp"
    },
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp"
    },
    "qonto-qa-master": {
      "type": "remote",
      "url": "https://qa-master.staging.qonto.co/mcp"
    },
    "qonto-qa-qa": {
      "type": "remote",
      "url": "https://qa-qa.staging.qonto.co/mcp"
    }
  },
  "agent": {
    "cheap-researcher": {
      "description": "Solves easy tasks without involving the big guns",
      "mode": "primary",
      "model": "opencode/big-pickle",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "cheap-worker": {
      "mode": "primary",
      "model": "anthropic/claude-haiku-4-5",
      "descirption": "A cheap worker to solve trivial and quick tasks",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    }
  }
}
