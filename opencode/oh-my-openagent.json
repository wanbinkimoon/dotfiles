{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max",
      "mode": "primary",
      "fallback_models": [
        "openai/gpt-5.4",
        "anthropic/claude-sonnet-4-6"
      ],
      "compaction": {
        "model": "anthropic/claude-sonnet-4-6"
      },
      "prompt_append": "DELEGATION OVERRIDE: For ANY code-writing delegation (new features, refactors, bug fixes, file creation), ALWAYS use category='deep' to route to Hephaestus. Reserve category='quick' ONLY for non-code tasks (config edits, typo fixes in text, simple renames). Sisyphus-Junior is for lightweight non-code tasks only."
    },
    "sisyphus-junior": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "hephaestus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "anthropic/claude-opus-4-6"
      ]
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        "anthropic/claude-sonnet-4-6"
      ]
    },
    "explore": {
      "model": "github-copilot/grok-code-fast-1",
      "fallback_models": [
        "anthropic/claude-haiku-4-5",
        "openai/gpt-5.4-mini"
      ]
    },
    "librarian": {
      "model": "anthropic/claude-haiku-4-5",
      "fallback_models": [
        "openai/gpt-5.4-mini",
        "openai/gpt-5.4"
      ]
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.4",
      "fallback_models": [
        "anthropic/claude-sonnet-4-6"
      ]
    },
    "prometheus": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max",
      "fallback_models": [
        "openai/gpt-5.3-codex"
      ]
    },
    "metis": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max",
      "fallback_models": [
        "openai/gpt-5.4",
        "openai/gpt-5.3-codex"
      ]
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "fallback_models": [
        "anthropic/claude-sonnet-4-6",
        "anthropic/claude-opus-4-6"
      ]
    },
    "atlas": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": [
        "openai/gpt-5.4",
        "openai/gpt-5.4-mini"
      ]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        "openai/gpt-5.4",
        "anthropic/claude-sonnet-4-6"
      ]
    },
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "anthropic/claude-opus-4-6",
        "anthropic/claude-sonnet-4-6"
      ]
    },
    "deep": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "fallback_models": [
        "anthropic/claude-opus-4-6",
        "anthropic/claude-sonnet-4-6"
      ]
    },
    "artistry": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max",
      "fallback_models": [
        "openai/gpt-5.4",
        "openai/gpt-5.3-codex"
      ]
    },
    "quick": {
      "model": "anthropic/claude-haiku-4-5",
      "fallback_models": [
        "openai/gpt-5.4-mini",
        "anthropic/claude-sonnet-4-6"
      ]
    },
    "unspecified-low": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": [
        "openai/gpt-5.4",
        "openai/gpt-5.4-mini"
      ]
    },
    "unspecified-high": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max",
      "fallback_models": [
        "openai/gpt-5.4",
        "openai/gpt-5.3-codex"
      ]
    },
    "writing": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": [
        "openai/gpt-5.4",
        "openai/gpt-5.4-mini"
      ]
    }
  },
  "background_task": {
    "providerConcurrency": {
      "anthropic": 3,
      "openai": 5,
      "opencode": 10,
      "github-copilot": 5
    },
    "modelConcurrency": {
      "anthropic/claude-opus-4-6": 2,
      "opencode/gpt-5-nano": 20
    }
  },
  "hashline_edit": true,
  "_migrations": [
    "model-version:anthropic/claude-sonnet-4-5->anthropic/claude-sonnet-4-6",
    "model-version:openai/gpt-5.3-codex->openai/gpt-5.4",
    "model-version:openai/gpt-5.3-codex->openai/gpt-5.4",
    "model-version:openai/gpt-5.3-codex->openai/gpt-5.4"
  ]
}
